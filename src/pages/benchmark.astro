function copyBibtex(btn) {
  const pre = btn.closest('.bibtex-block').querySelector('pre code');
  const text = pre.textContent
    .replace(/&#123;/g, '{')
    .replace(/&#125;/g, '}');
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = 'Copied!';
