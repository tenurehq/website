            <th>Turn</th>
            <th>Tenure</th>
            <th>Vector</th>
            <th>Mem0</th>
            <th>Zep</th>
            <th>Hindsight</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td>Turn 9 — implicit re-entry</td>
            <td><span class="val-good">0.00</span></td>
            <td><span class="val-bad">1.00</span></td>
            <td><span class="val-bad">1.00</span></td>
            <td><span class="val-bad">1.00</span></td>
            <td><span class="val-bad">1.00</span></td>
          </tr>
          <tr>
            <td>Turn 10 — explicit re-entry</td>
            <td><span class="val-good">0.00</span></td>
            <td><span class="val-bad">0.94</span></td>
            <td><span class="val-bad">1.00</span></td>
            <td><span class="val-bad">1.00</span></td>
            <td><span class="val-bad">0.94</span></td>
          </tr>
          <tr>
