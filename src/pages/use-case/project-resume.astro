}
.resume-file-visits {
  font-family: var(--mono);
  font-size: 0.65rem;
  color: var(--dim);
}

.resume-belief-list { display: flex; flex-direction: column; gap: 0.5rem; }
.resume-belief {
  display: flex;
  align-items: flex-start;
  gap: 0.6rem;
  font-size: 0.8rem;
}
.resume-belief-text { color: var(--muted); }

.belief-type {
  font-family: var(--mono);
  font-size: 0.62rem;
  padding: 0.15em 0.5em;
  border-radius: 4px;
  font-weight: 600;
  flex-shrink: 0;
  letter-spacing: 0.04em;
}
.type-decision  { background: rgba(0,168,173,0.1); color: var(--accent); border: 1px solid rgba(0,168,173,0.2); }
.type-preference { background: rgba(168,100,0,0.1); color: #c47a30; border: 1px solid rgba(168,100,0,0.2); }

.resume-query-list { display: flex; flex-direction: column; gap: 0.4rem; }
.resume-query {
  font-family: var(--mono);
  font-size: 0.73rem;
  color: var(--dim);
  padding: 0.4rem 0.75rem;
  background: var(--surface2);
  border: 1px solid var(--border);
