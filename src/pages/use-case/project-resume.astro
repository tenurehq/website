.resume-query::before { content: '"'; }
.resume-query::after  { content: '"'; }

.resume-next-list { display: flex; flex-direction: column; gap: 0.4rem; }
.resume-next {
  font-size: 0.82rem;
  color: var(--muted);
  padding: 0.3rem 0;
}

.resume-actions {
  display: flex;
  gap: 0.65rem;
  margin-top: 1.5rem;
  flex-wrap: wrap;
}
.resume-btn-primary {
  background: var(--accent);
  color: #fff;
  border: none;
  border-radius: 7px;
  padding: 0.5rem 1.1rem;
  font-size: 0.82rem;
  font-weight: 600;
