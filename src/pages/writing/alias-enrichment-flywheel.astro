  "author": { "@type": "Organization", "name": "Tenure", "url": "https://tenureai.dev" },
  "publisher": { "@type": "Organization", "name": "Tenure", "url": "https://tenureai.dev" },
  "url": "https://tenureai.dev/writing/alias-enrichment-flywheel",
  "description": "BM25 retrieval is only as good as the alias set it searches against. The flywheel is how that set grows: passively, continuously, and without any effort from the user.",
