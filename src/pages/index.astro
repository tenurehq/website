                    fill="#ffffff"
                  />
                  <path
                    d="M10 9.24847C10 8.55811 9.44036 7.99847 8.75 7.99847C8.05964 7.99847 7.5 8.55811 7.5 9.24847C7.5 9.93882 8.05964 10.4986 8.75 10.4986C9.44036 10.4986 10 9.93882 10 9.24847Z"
                    fill="#ffffff"
                  />
                  <path
                    d="M16.9216 10.5837C16.9216 9.89333 16.3619 9.33368 15.6716 9.33368C14.9812 9.33368 14.4216 9.89333 14.4216 10.5837C14.4216 11.274 14.9812 11.8338 15.6716 11.8338C16.3619 11.8338 16.9216 11.274 16.9216 10.5837Z"
                    fill="#ffffff"
