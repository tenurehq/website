  <style>
    .architecture-section {
      position: relative;
      overflow: hidden;
    }

    .architecture-shell {
      max-width: 660px;
      margin: 0 auto 0;
      padding: 0.85rem;
      border: 1px solid rgba(0, 168, 173, 0.22);
      border-radius: 20px;
      background:
        radial-gradient(circle at top, rgba(0, 168, 173, 0.18), transparent 34%),
        linear-gradient(180deg, rgba(255,255,255,0.045), rgba(255,255,255,0.015));
    }

    .architecture-row {
      display: grid;
      gap: 0.45rem;
    }

    .architecture-row-top {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .architecture-row-bottom-models {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .groundeval-strip {
      max-width: 660px;
      margin: 1.25rem auto 0;
      padding: 0.65rem 0.8rem;
      border: 1px dashed rgba(108, 92, 231, 0.4);
      border-radius: 14px;
      background: rgba(108, 92, 231, 0.05);
    }

    .groundeval-label {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
      margin-bottom: 0.7rem;
    }

    .groundeval-kicker {
      font-size: 0.72rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--violet, #a29bfe);
      padding: 0.2rem 0.55rem;
      border-radius: 999px;
      border: 1px solid rgba(108, 92, 231, 0.35);
      background: rgba(108, 92, 231, 0.14);
    }

    .groundeval-caption {
      font-size: 0.85rem;
      color: var(--dim, #7a7a7a);
    }

    .groundeval-steps {
      display: grid;
      grid-template-columns: 1fr auto 1fr auto 1fr;
      align-items: center;
      gap: 0.5rem;
    }

    .groundeval-step {
      padding: 0.45rem 0.55rem;
      border-radius: 10px;
      background: var(--violet, #6c5ce7);
      border: 1px solid rgba(108, 92, 231, 0.5);
      text-align: center;
    }

    .groundeval-step strong {
      display: block;
      font-size: 0.74rem;
      color: #ffffff;
      margin-bottom: 0.15rem;
    }

    .groundeval-step span {
      display: block;
      font-size: 0.64rem;
      color: rgba(255, 255, 255, 0.78);
    }

    .groundeval-arrow {
      color: rgba(255, 255, 255, 0.55);
      font-size: 1.1rem;
      text-align: center;
    }

    .groundeval-connector {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 0.15rem 0;
}

.groundeval-connector-line {
  position: relative;
  width: 1px;
  height: 20px;
  background: linear-gradient(180deg, rgba(108,92,231,0.15), rgba(108,92,231,0.9));
}

.groundeval-connector-line::after {
  content: "";
  position: absolute;
  left: -4px;
  top: 12px;
  width: 8px;
  height: 8px;
  border-right: 1px solid rgba(108,92,231,0.9);
  border-bottom: 1px solid rgba(108,92,231,0.9);
  transform: rotate(45deg);
}

.groundeval-connector-label {
  margin-top: 0.3rem;
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--violet, #a29bfe);
  letter-spacing: 0.02em;
}

    .policy-control {
      border-color: rgba(108, 92, 231, 0.5);
      background: var(--violet, #6c5ce7);
    }

    .policy-control strong,
    .policy-control span {
      color: #ffffff;
    }

    .architecture-node {
      min-height: 34px;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 0.4rem;
      border-radius: 10px;
      font-weight: 700;
      font-size: 0.74rem;
      letter-spacing: -0.01em;
      color: var(--fg, #e8e8e8);
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
    }

    .client-node {
      border-color: rgba(255,255,255,0.11);
    }

    .model-node {
      background: rgba(0,0,0,0.22);
      border-color: rgba(0,168,173,0.18);
      color: var(--dim, #a6a6a6);
    }

    .architecture-arrow-row {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 0.45rem;
      padding: 0.15rem 0;
    }

    .architecture-arrow-row-bottom {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .architecture-arrow-row span {
      height: 14px;
      position: relative;
    }

    .architecture-arrow-row span::before {
      content: "";
      position: absolute;
      left: 50%;
      top: 0;
      width: 1px;
      height: 8px;
      background: rgba(255,255,255,0.28);
    }

    .architecture-arrow-row span::after {
      content: "";
      position: absolute;
      left: calc(50% - 3px);
      top: 6px;
      width: 6px;
      height: 6px;
      border-right: 1px solid rgba(255,255,255,0.4);
      border-bottom: 1px solid rgba(255,255,255,0.4);
      transform: rotate(45deg);
    }

    .architecture-gateway {
      position: relative;
      padding: 1rem;
      border-radius: 18px;
      border: 1px solid rgba(0,168,173,0.4);
      background:
        linear-gradient(160deg, rgba(0,168,173,0.3), rgba(0,168,173,0.08)),
        #0b2e2b;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04);
    }

    .beta-badge {
      position: absolute;
      top: 0.7rem;
      right: 0.7rem;
      z-index: 2;
      padding: 0.25rem 0.6rem;
      border-radius: 999px;
      background: rgba(245,158,11,0.16);
      border: 1px solid rgba(245,158,11,0.4);
      color: #f5a623;
      font-size: 0.62rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    @media (max-width: 640px) {
      .beta-badge {
        top: 0.5rem;
        right: 0.5rem;
        font-size: 0.56rem;
        padding: 0.2rem 0.45rem;
      }
    }

    .architecture-gateway-header {
      max-width: 660px;
      margin: 0 auto 0.55rem;
      text-align: center;
    }

    .architecture-kicker {
      display: inline-flex;
      align-items: center;
      margin-bottom: 0.4rem;
      padding: 0.2rem 0.5rem;
      border-radius: 999px;
      background: rgba(0,168,173,0.16);
      border: 1px solid rgba(0,168,173,0.28);
      color: var(--accent, #00a8ad);
      font-size: 0.62rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .architecture-gateway h3 {
      margin: 0;
      font-size: clamp(1.05rem, 2.2vw, 1.35rem);
      letter-spacing: -0.03em;
    }

    .architecture-gateway p {
      margin: 0.3rem auto 0;
      color: var(--dim, #9a9a9a);
      font-size: 0.76rem;
      line-height: 1.4;
    }

    .architecture-controls {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.5rem;
      margin-top: 0.6rem;
    }

    .architecture-control {
      text-align: center;
      min-height: 56px;
      padding: 0.55rem 0.65rem;
      border-radius: 12px;
      background: rgba(10,10,10,0.42);
      border: 1px solid rgba(255,255,255,0.08);
    }

    .architecture-control strong,
    .architecture-control span {
      display: block;
    }

    .architecture-control strong {
      margin-bottom: 0.8rem;
      color: var(--fg, #f0f0f0);
      font-size: 0.8rem;
    }

    .architecture-control span {
      color: var(--dim, #9a9a9a);
      font-size: 0.7rem;
      line-height: 1.3;
    }

    .context-lanes {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.35rem;
      margin-top: 0.6rem;
      padding-top: 0.6rem;
      border-top: 1px solid rgba(255,255,255,0.08);
    }

    .context-lanes span {
      padding: 0.25rem 0.5rem;
      border-radius: 999px;
      border: 1px solid rgba(0,168,173,0.22);
      background: rgba(0,168,173,0.08);
      color: var(--fg, #e8e8e8);
      font-size: 0.65rem;
      font-weight: 700;
    }

    .architecture-caption {
      max-width: 660px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.6rem;
      margin: 0.75rem auto 0;
    }

    .architecture-caption > div {
      padding: 0.6rem;
      border-radius: 12px;
      background: rgba(255,255,255,0.035);
      border: 1px solid rgba(255,255,255,0.07);
      color: var(--dim, #9a9a9a);
      font-size: 0.78rem;
      line-height: 1.4;
    }

    .architecture-caption strong {
      color: var(--fg, #eeeeee);
    }

    @media (max-width: 900px) {
      .architecture-row-top,
      .architecture-controls,
      .architecture-row-bottom-models,
      .architecture-caption {
        grid-template-columns: 1fr 1fr;
      }

      .architecture-arrow-row,
      .architecture-arrow-row-bottom {
        grid-template-columns: 1fr;
      }

      .architecture-arrow-row span:not(:first-child) {
        display: none;
      }
    }

    @media (max-width: 640px) {
      .architecture-shell {
        padding: 1rem;
        border-radius: 22px;
      }

      .architecture-row-top,
      .architecture-controls,
      .architecture-row-bottom-models,
      .architecture-caption {
        grid-template-columns: 1fr;
      }

      .groundeval-steps {
        grid-template-columns: 1fr;
      }

      .groundeval-arrow {
        transform: rotate(90deg);
      }
    }
  </style>

