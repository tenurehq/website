import Base from '../layouts/Base.astro';

const title = "Privacy Policy | Tenure";
const description = "How Tenure accesses, collects, stores, uses, and shares your personal information when you use our Services.";
---

<Base title={title} description={description}>
  <section id="legal-hero">
    <div class="container">
      <span class="label">Legal</span>
      <h1>Privacy Policy</h1>
      <p class="legal-updated">Last updated July 22, 2026</p>
    </div>
  </section>

  <section id="legal-content">
    <div class="container legal-layout">
      <aside class="legal-toc">
        <p class="legal-toc-label">Table of Contents</p>
        <div class="legal-toc-links">
          <a href="#infocollect">1. What information do we collect?</a>
