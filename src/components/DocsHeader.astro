---
const { title, description, canonical } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, "https://tenureai.dev").href;
import Search from '@astrojs/starlight/components/Search.astro';
---

    <nav transition:persist>
      <span class="nav-logo">
        <a href="/" class="logo-container" transition:persist>
          <img
            src="/images/tenure-logo-small.svg"
            class="logo-icon"
            alt="tenure"
            transition:persist
          />
          tenure
        </a>
      </span>

      <div class="docs-header-center">
      <Search />
    </div>

      <div class="nav-links">


<div class="dropdown dropdown--mega">
  <button class="dropdown-trigger">
    Platform <span class="dropdown-arrow">▼</span>
  </button>

  <div class="mega-menu">
    <div class="mega-menu__bridge"></div>

    <div class="mega-menu__panel">

      <div class="mega-col">
        <p class="mega-col__label">How Teams Build Trust</p>
        <div class="mega-col__divider"></div>

        <a href="/use-case/memory-modes" class="mega-item">
          <span class="mega-item__title">Memory Modes</span>
          <span class="mega-item__desc">Adapt memory to your team's trust level.</span>
        </a>

        <a href="/use-case/code-review" class="mega-item">
          <span class="mega-item__title">PR Review</span>
          <span class="mega-item__desc">Persistent knowledge for code reviews.</span>
        </a>

        <a href="/use-case/mobile" class="mega-item">
          <span class="mega-item__title">Mobile</span>
          <span class="mega-item__desc">Capture context anywhere.</span>
        </a>
      </div>

      <div class="mega-col__separator"></div>

      <div class="mega-col">
        <p class="mega-col__label">Where Tenure Runs</p>
        <div class="mega-col__divider"></div>

        <a href="/use-case/vscode" class="mega-item">
          <span class="mega-item__title">VS Code</span>
          <span class="mega-item__desc">Native AI provider integration.</span>
        </a>

        <a href="/use-case/vscodium" class="mega-item">
          <span class="mega-item__title">VSCodium</span>
          <span class="mega-item__desc">Open-source editor support.</span>
        </a>
      </div>

      <div class="mega-col__separator"></div>

      <div class="mega-col">
        <p class="mega-col__label">Compatible Clients</p>
        <div class="mega-col__divider"></div>

        <a href="/docs/clients/open-webui" class="mega-item">
          <span class="mega-item__title">Open WebUI</span>
          <span class="mega-item__desc">Browser-based chat interface.</span>
        </a>

        <a href="/docs/clients/openclaw" class="mega-item">
          <span class="mega-item__title">OpenClaw</span>
          <span class="mega-item__desc">Self-hosted agent gateway.</span>
        </a>
      </div>

    </div>
  </div>
</div>
        <div class="dropdown">
          <button class="dropdown-trigger">
            Teams <span class="dropdown-arrow">▼</span>
          </button>
          <div class="dropdown-content">
            <a href="/teams">Overview</a>
            <a href="/teams/shared-memory">Shared Memory</a>
            <a href="/teams/ai-governance">AI Governance</a>
          </div>
        </div>
        <a href="/docs">Docs</a>
        <a href="https://github.com/tenurehq/tenure">GitHub</a>
        <a href="/writing">Writing</a>
        <div class="dropdown">
          <button class="dropdown-trigger">
            Research <span class="dropdown-arrow">▼</span>
          </button>
          <div class="dropdown-content">
            <a href="/benchmark">Benchmark</a>
            <a href="https://arxiv.org/abs/2605.11325">Paper</a>
          </div>
        </div>
        <a href="https://github.com/tenurehq/tenure">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" transform="rotate(0 0 0)">
        <path d="M12 2.24902C6.51613 2.24902 2 6.70064 2 12.249C2 16.6361 4.87097 20.3781 8.87097 21.7329C9.3871 21.8297 9.54839 21.5071 9.54839 21.2813C9.54839 21.0555 9.54839 20.4103 9.51613 19.5393C6.74194 20.1845 6.16129 18.1845 6.16129 18.1845C5.70968 17.0555 5.03226 16.7329 5.03226 16.7329C4.12903 16.0877 5.06452 16.0877 5.06452 16.0877C6.06452 16.12 6.6129 17.12 6.6129 17.12C7.48387 18.6684 8.96774 18.2168 9.51613 17.9264C9.6129 17.2813 9.87097 16.8297 10.1613 16.5716C7.96774 16.3458 5.6129 15.4748 5.6129 11.6684C5.6129 10.5716 6.03226 9.70064 6.64516 9.02322C6.54839 8.79741 6.19355 7.76515 6.74194 6.37806C6.74194 6.37806 7.6129 6.11999 9.51613 7.41031C10.3226 7.18451 11.1613 7.05548 12.0323 7.05548C12.9032 7.05548 13.7742 7.15225 14.5484 7.41031C16.4516 6.15225 17.2903 6.37806 17.2903 6.37806C17.8387 7.73289 17.5161 8.79741 17.3871 9.02322C18.0323 9.70064 18.4194 10.6039 18.4194 11.6684C18.4194 15.4748 16.0645 16.3458 13.871 16.5716C14.2258 16.8942 14.5484 17.5393 14.5484 18.4426C14.5484 19.7974 14.5161 20.8619 14.5161 21.1845C14.5161 21.4426 14.7097 21.7329 15.1935 21.6361C19.129 20.3135 22 16.6039 22 12.1845C21.9677 6.70064 17.4839 2.24902 12 2.24902Z" fill="#ffffff"/>
        </svg>
        </a>

       
      </div>

   
    </nav>


<style>
.docs-header-center {
    flex: 1;
    max-width: 400px;
  }

  a {
  color: inherit;
  text-decoration: none;
}

nav {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 2rem;
  height: 56px;
  background: rgba(10, 10, 10, 0.92);
  backdrop-filter: blur(12px);
}

.nav-logo {
  font-family: var(--mono);
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: var(--text);
}

.nav-links {
  display: flex;
  gap: 2rem;
  align-items: center;
}

.nav-links a {
  font-size: 0.85rem;
  color: var(--muted);
  transition: color 0.15s;
}

.nav-links a:hover {
  color: var(--text);
}

.nav-cta {
  background: var(--accent);
  color: #fff !important;
  padding: 0.4rem 1rem;
  border-radius: 6px;
  font-size: 0.85rem;
  font-weight: 500;
  transition: background 0.15s !important;
}

.nav-cta:hover {
  background: var(--accent2) !important;
}

/* ── NAV DROPDOWN ── */
.dropdown {
  position: relative;
  display: inline-block;
}

.dropdown-trigger {
  background: none;
  border: none;
  font-family: var(--font);
  font-size: 0.85rem;
  color: var(--muted);
  cursor: pointer;
  padding: 0;
  display: flex;
  align-items: center;
  gap: 0.3rem;
  transition: color 0.15s;
}

.dropdown-arrow {
  font-size: 0.6rem;
  color: var(--dim);
  transition: transform 0.15s;
}

.dropdown:hover .dropdown-trigger {
  color: var(--text);
}

.dropdown:hover .dropdown-arrow {
  transform: rotate(180deg);
  color: var(--accent);
}

.dropdown-content {
  display: none;
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  background-color: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  min-width: 140px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
  z-index: 110;
  padding: 0.5rem 0;
  margin-top: 0.75rem;
}

.dropdown-content::before {
  content: "";
  position: absolute;
  top: -1rem;
  left: 0;
  width: 100%;
  height: 1.2rem;
  background: transparent;
}

.dropdown:hover .dropdown-content {
  display: block;
}

.dropdown-content a {
  color: var(--muted) !important;
  padding: 0.5rem 1.25rem;
  display: block;
  font-size: 0.85rem;
  transition:
    background 0.15s,
    color 0.15s;
  text-align: left;
}

.dropdown-content a:hover {
  background: var(--surface2);
  color: var(--text) !important;
}

.nav-hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  z-index: 200;
}

.nav-hamburger span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--muted);
  border-radius: 2px;
  transition:
    transform 0.2s,
    opacity 0.2s,
    background 0.15s;
  transform-origin: center;
}

.nav-hamburger.open span:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
  background: var(--text);
}
.nav-hamburger.open span:nth-child(2) {
  opacity: 0;
}
.nav-hamburger.open span:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
  background: var(--text);
}

.nav-mobile-menu {
  display: none;
  position: fixed;
  top: 56px;
  left: 0;
  right: 0;
  z-index: 99;
  background: rgba(10, 10, 10, 0.97);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  flex-direction: column;
  padding: 1rem 1.5rem 1.5rem;
  gap: 0;
}

.nav-mobile-menu.open {
  display: flex;
}

.nav-mobile-menu a {
  font-size: 0.95rem;
  color: var(--muted);
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--border);
  transition: color 0.15s;
}

.nav-mobile-menu a:last-of-type {
  border-bottom: none;
}

.nav-mobile-menu a:hover {
  color: var(--text);
}

.nav-mobile-cta {
  margin-top: 1rem;
  background: var(--accent) !important;
  color: #fff !important;
  text-align: center;
  padding: 0.65rem 1rem !important;
  border-radius: 6px;
  font-weight: 500;
  border-bottom: none !important;
}

.nav-mobile-cta:hover {
  background: var(--accent2) !important;
}

.dropdown--mega {
  position: relative;
}

.mega-menu {
  display: none;
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translateX(-50%);
  padding-top: 12px;
  z-index: calc(var(--sl-z-index-navbar) + 10);
}

.mega-menu__bridge {
  height: 12px;
  width: 100%;
}

.mega-menu__panel {
  display: flex;
  gap: 0;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 10px;
  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.55);
  padding: 1.5rem 0;
  min-width: 580px;
  overflow: hidden;
}

.dropdown--mega:hover .mega-menu {
  display: block;
}

.mega-col {
  flex: 1;
  padding: 0 1.75rem;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.mega-col__label {
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--dim);
  margin: 0 0 0.6rem 0;
  white-space: nowrap;
}

.mega-col__divider {
  height: 1px;
  background: var(--border);
  margin-bottom: 0.85rem;
}

.mega-col__separator {
  width: 1px;
  background: var(--border);
  margin: 0;
  flex-shrink: 0;
}

.mega-item {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
  padding: 0.55rem 0.6rem;
  border-radius: 6px;
  transition: background 0.12s;
  text-decoration: none;
  margin: 0 -0.6rem;
}

.mega-item:hover {
  background: var(--surface2);
}

.mega-item__title {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text);
  line-height: 1.2;
  transition: color 0.12s;
}

.mega-item__desc {
  font-size: 0.76rem;
  color: var(--dim);
  line-height: 1.4;
}

.mega-item:hover .mega-item__title {
  color: var(--accent);
}

.logo-icon {
  margin-right: 7px;
  height: 30px;
}
.logo-container {
  display: flex;
}

.header {
  padding: 0;
  padding-inline-end: 0;
  z-index: var(--sl-z-index-navbar);
}


</style>