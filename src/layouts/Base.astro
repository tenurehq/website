---
const { title, description, canonical } = Astro.props;
const canonicalURL = canonical ?? new URL(Astro.url.pathname, "https://tenureai.dev").href;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="AI memory, developer memory tool, local LLM memory, persistent AI context, VS Code AI memory, localhost AI, coding assistant memory, AI context injection, no RAG memory, AI productivity"
    />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://tenureai.dev" />
    <meta
      property="og:title"
      content="Tenure | Persistent, Governable, Scoped State for AI Systems"
    />
    <meta
      property="og:description"
      content="Your memory system will drift in ways you cannot detect. Persistent, governable, scoped state for AI systems. Hard boundaries. Full provenance. Audit trails from day one."
    />
    <meta property="og:image" content="https://tenureai.dev/og-image.png" />
    <meta property="og:site_name" content="Tenure" />
    <meta name="robots" content="index, follow" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://tenureai.dev" />
    <meta
      name="twitter:title"
      content="Tenure | Persistent, Governable, Scoped State for AI Systems"
    />
    <meta
      name="twitter:description"
      content="Your memory system will drift in ways you cannot detect. Persistent, governable, scoped state for AI systems. Hard boundaries. Full provenance. Audit trails from day one."
    />
    <meta name="twitter:image" content="https://tenureai.dev/og-image.png" />
    <meta
      name="description:extended"
      content="Your memory system will drift in ways you cannot detect. Persistent, governable, scoped state for AI systems. Hard boundaries. Full provenance. Audit trails from day one."
    />
    <meta
  name="ai:product-type"
  content="AI state infrastructure, governance layer, LLM proxy"
    />
    <meta
      name="ai:use-case"
      content="persistent governable state for AI systems, memory drift prevention, scoped belief isolation, AI access governance for engineering teams"
    />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "SoftwareApplication",
            "@id": "https://tenureai.dev/#software",
            "name": "Tenure",
            "url": "https://tenureai.dev",
            "codeRepository": "https://github.com/tenurehq/tenure",
            "image": "https://tenureai.dev/og-image.png",
            "applicationCategory": "DeveloperApplication",
            "operatingSystem": "Linux, macOS, Windows",
            "description": "Your memory system will drift in ways you cannot detect. Persistent, governable, scoped state for AI systems. Hard boundaries. Full provenance. Audit trails from day one.",
            "offers": {
              "@type": "Offer",
              "price": "0",
              "priceCurrency": "USD",
              "availability": "https://schema.org/InStock"
            },
            "license": "https://opensource.org/licenses/MIT"
          },
          {
            "@type": "Dataset",
            "@id": "https://tenureai.dev/#dataset",
            "name": "precisionMemBench",
            "description": "A multi-dimensional retrieval benchmark for LLM memory systems measuring retrieval precision, noise isolation, session-turn latency, and belief mutability across 89 cases and 11 providers.",
            "url": "https://huggingface.co/datasets/tenurehq/precisionmembench",
            "sameAs": [
              "https://arxiv.org/abs/2605.11325",
              "https://github.com/tenurehq/precisionMemBench"
            ],
            "license": "https://opensource.org/licenses/MIT",
            "creator": {
              "@type": "Organization",
              "name": "Tenure",
              "url": "https://tenureai.dev"
            },
            "about": {
              "@id": "https://tenureai.dev/#software"
            }
          }
        ]
      }
    </script>
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="stylesheet" href="/styles/index.css" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script
        src="https://white.tenureai.dev/api/script.js"
        data-site-id="b3ed469cd2e0"
        defer
    ></script>
  </head>
  <body>
    <nav>
      <span class="nav-logo logo-container">
        <a href="/" class="logo-container">
          <img
            src="/images/tenure-logo-small.svg"
            class="logo-icon"
            alt="tenure"
          />
          tenure
        </a>
      </span>
      <div class="nav-links">


<div class="dropdown dropdown--mega">
  <button class="dropdown-trigger">
    Platform <span class="dropdown-arrow">▼</span>
  </button>

  <div class="mega-menu">
    <div class="mega-menu__bridge"></div>

    <div class="mega-menu__panel">

      <div class="mega-col">
        <p class="mega-col__label">How Teams Build Trust</p>
        <div class="mega-col__divider"></div>

        <a href="/use-case/memory-modes" class="mega-item">
          <span class="mega-item__title">Memory Modes</span>
          <span class="mega-item__desc">Adapt memory to your team's trust level.</span>
        </a>

        <a href="/use-case/code-review" class="mega-item">
          <span class="mega-item__title">PR Review</span>
          <span class="mega-item__desc">Persistent knowledge for code reviews.</span>
        </a>

        <a href="/use-case/mobile" class="mega-item">
          <span class="mega-item__title">Mobile</span>
          <span class="mega-item__desc">Capture context anywhere.</span>
        </a>
      </div>

      <div class="mega-col__separator"></div>

      <div class="mega-col">
        <p class="mega-col__label">Where Tenure Runs</p>
        <div class="mega-col__divider"></div>

        <a href="/use-case/vscode" class="mega-item">
          <span class="mega-item__title">VS Code</span>
          <span class="mega-item__desc">Native AI provider integration.</span>
        </a>

        <a href="/use-case/vscodium" class="mega-item">
          <span class="mega-item__title">VSCodium</span>
          <span class="mega-item__desc">Open-source editor support.</span>
        </a>
      </div>

      <div class="mega-col__separator"></div>

      <div class="mega-col">
        <p class="mega-col__label">Compatible Clients</p>
        <div class="mega-col__divider"></div>

        <a href="/docs/clients/open-webui" class="mega-item">
          <span class="mega-item__title">Open WebUI</span>
          <span class="mega-item__desc">Browser-based chat interface.</span>
        </a>

        <a href="/docs/clients/openclaw" class="mega-item">
          <span class="mega-item__title">OpenClaw</span>
          <span class="mega-item__desc">Self-hosted agent gateway.</span>
        </a>
      </div>

    </div>
  </div>
</div>
        <div class="dropdown">
          <button class="dropdown-trigger">
            Teams <span class="dropdown-arrow">▼</span>
          </button>
          <div class="dropdown-content">
            <a href="/teams">Overview</a>
            <a href="/teams/shared-memory">Shared Memory</a>
            <a href="/teams/ai-governance">AI Governance</a>
          </div>
        </div>
        <a href="/docs">Docs</a>
        <a href="https://github.com/tenurehq/tenure">GitHub</a>
        <a href="/writing">Writing</a>
        <div class="dropdown">
          <button class="dropdown-trigger">
            Research <span class="dropdown-arrow">▼</span>
          </button>
          <div class="dropdown-content">
            <a href="/benchmark">Benchmark</a>
            <a href="https://arxiv.org/abs/2605.11325">Paper</a>
          </div>
        </div>
        <a href="https://github.com/tenurehq/tenure">
        <svg width="30" height="30" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" transform="rotate(0 0 0)">
        <path d="M12 2.24902C6.51613 2.24902 2 6.70064 2 12.249C2 16.6361 4.87097 20.3781 8.87097 21.7329C9.3871 21.8297 9.54839 21.5071 9.54839 21.2813C9.54839 21.0555 9.54839 20.4103 9.51613 19.5393C6.74194 20.1845 6.16129 18.1845 6.16129 18.1845C5.70968 17.0555 5.03226 16.7329 5.03226 16.7329C4.12903 16.0877 5.06452 16.0877 5.06452 16.0877C6.06452 16.12 6.6129 17.12 6.6129 17.12C7.48387 18.6684 8.96774 18.2168 9.51613 17.9264C9.6129 17.2813 9.87097 16.8297 10.1613 16.5716C7.96774 16.3458 5.6129 15.4748 5.6129 11.6684C5.6129 10.5716 6.03226 9.70064 6.64516 9.02322C6.54839 8.79741 6.19355 7.76515 6.74194 6.37806C6.74194 6.37806 7.6129 6.11999 9.51613 7.41031C10.3226 7.18451 11.1613 7.05548 12.0323 7.05548C12.9032 7.05548 13.7742 7.15225 14.5484 7.41031C16.4516 6.15225 17.2903 6.37806 17.2903 6.37806C17.8387 7.73289 17.5161 8.79741 17.3871 9.02322C18.0323 9.70064 18.4194 10.6039 18.4194 11.6684C18.4194 15.4748 16.0645 16.3458 13.871 16.5716C14.2258 16.8942 14.5484 17.5393 14.5484 18.4426C14.5484 19.7974 14.5161 20.8619 14.5161 21.1845C14.5161 21.4426 14.7097 21.7329 15.1935 21.6361C19.129 20.3135 22 16.6039 22 12.1845C21.9677 6.70064 17.4839 2.24902 12 2.24902Z" fill="#ffffff"/>
        </svg>
        </a>

       
      </div>

      <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </nav>

    <div class="nav-mobile-menu" id="nav-mobile-menu">
      <a href="/use-case/mobile">Mobile</a>
      <a href="/use-case/vscode">VSCode</a>
      <a href="/use-case/vscodium">VSCodium</a>
      <a href="/docs">Docs</a>
      <a href="https://github.com/tenurehq/tenure">GitHub</a>
      <a href="/writing">Writing</a>
      <a href="/benchmark">Benchmark</a>
      <a href="https://arxiv.org/abs/2605.11325">Paper</a>
      <a href="https://github.com/tenurehq/tenure" class="nav-mobile-cta">Install Free</a>
    </div>

    <script>
      const btn = document.getElementById('nav-hamburger');
      const menu = document.getElementById('nav-mobile-menu');
      btn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('open');
        btn.classList.toggle('open', open);
      });
      menu?.querySelectorAll('a').forEach(a =>
        a.addEventListener('click', () => {
          menu.classList.remove('open');
          btn?.classList.remove('open');
        })
      );
    </script>

    <slot />

    <footer>
      <div class="footer-container">
        <div class="footer-brand">
          <span class="footer-logo">tenure &middot; MIT License</span>
           <a href="https://github.com/tenurehq/tenure">
